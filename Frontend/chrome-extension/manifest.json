{
  "manifest_version": 3,
  "name": "WebRAG Page Assistant",
  "version": "1.0.0",
  "description": "Toolbar icon opens a side panel to scrape the active tab and chat with WebRAG.",
  "permissions": ["activeTab", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:4173/*",
    "http://127.0.0.1:4173/*"
  ],
  "action": {
    "default_title": "WebRAG — open side panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
